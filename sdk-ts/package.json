{
  "name": "@bulwark-ai/sdk",
  "version": "0.1.0",
  "description": "Real-time monitoring, alerting, and emergency kill switch for AI agents.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "safety",
    "monitoring",
    "kill-switch",
    "observability"
  ],
  "author": "Bulwark <eng@bulwark.live>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samrat-shamim/bulwark"
  },
  "homepage": "https://bulwark.live",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0",
    "typescript": "^5.5",
    "vitest": "^2.0"
  }
}
